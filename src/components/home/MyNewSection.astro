---
import Button from "../common/button.astro";
---

<section class="w-full max-w-[1200px] mx-auto mt-24 px-6 overflow-hidden">
  <div class="text-center mb-4 relative"> 
    <h2 class="text-[28px] md:text-[40px] font-merriweather font-bold text-[#1E1E1E] inline-block relative">
      <a 
        href="https://docs.google.com/forms/d/e/1FAIpQLSf0QVTPz-FGFflZPywUXC__jOjQyfRWtzpPrJIXxiym4_aLDg/viewform" 
        target="_blank" 
        class="text-[#D33C0D] relative inline-block hover:brightness-110 transition-all group"
      >
        APPLY NOW
        <span class="absolute bottom-1 left-0 w-full h-[3px] bg-[#D33C0D] rounded-full opacity-30 group-hover:opacity-60"></span>
      </a> 
      – Kiran Prathibha 2026
    </h2>
    
    <p class="mt-2 text-[16px] md:text-[18px] font-poppins text-[#555] max-w-[900px] mx-auto flex items-center justify-center gap-3">
      Scholarship support for students pursuing 
      <span class="px-3 py-1 rounded-lg border border-[#D33C0D]/20 bg-[#D33C0D]/5 text-[#D33C0D] font-bold shadow-sm">
        Education, Arts, Sports
      </span>
    </p>

    <div class="w-48 h-[1px] bg-gradient-to-r from-transparent via-[#D33C0D] to-transparent mx-auto mt-4 animate-scan-horizontal"></div>
  </div>

  <div class="grid lg:grid-cols-2 gap-12 items-center">

    <div class="relative h-[450px] md:h-[550px] flex items-center justify-center overflow-hidden group">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_#D33C0D22_0%,_transparent_70%)] animate-pulse"></div>
      
      <div class="relative w-full h-full flex items-center justify-center">
        <div class="absolute inset-0 flex items-center justify-center focus-zoom-slide slide-1">
          <div class="relative w-[280px] md:w-[350px] aspect-[4/5] overflow-hidden rounded-2xl shadow-[0_20px_50px_rgba(211,60,13,0.25)] border border-[#D33C0D]/20">
            <img src="/assets/images/Homepage/8.png" alt="Education" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent"></div>
          </div>
        </div>

        <div class="absolute inset-0 flex items-center justify-center focus-zoom-slide slide-2">
          <div class="relative w-[280px] md:w-[350px] aspect-[4/5] overflow-hidden rounded-2xl shadow-[0_20px_50px_rgba(211,60,13,0.25)] border border-[#D33C0D]/20">
            <img src="/assets/images/Homepage/9.png" alt="Arts" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent"></div>
          </div>
        </div>

        <div class="absolute inset-0 flex items-center justify-center focus-zoom-slide slide-3">
          <div class="relative w-[280px] md:w-[350px] aspect-[4/5] overflow-hidden rounded-2xl shadow-[0_20px_50px_rgba(211,60,13,0.25)] border border-[#D33C0D]/20">
            <img src="/assets/images/Homepage/10.png" alt="Sports" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent"></div>
          </div>
        </div>

        <div class="absolute inset-0 flex items-center justify-center focus-zoom-slide slide-4">
          <div class="relative w-[280px] md:w-[350px] aspect-[4/5] overflow-hidden rounded-2xl shadow-[0_20px_50px_rgba(211,60,13,0.25)] border border-[#D33C0D]/20">
            <img src="/assets/images/Homepage/11.png" alt="Sports" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-10">
      <p class="text-[16px] md:text-[18px] font-poppins text-[#49494C] leading-relaxed border-l-4 border-[#D33C0D] pl-6">
        Kiran Foundation has been supporting talented and economically underprivileged students since 2016. Along with financial assistance, students receive mentorship and personal guidance to help them excel in their chosen fields.
      </p>

      <div class="flex flex-col gap-8">
        <div class="grid md:grid-cols-2 gap-8">
          <div class="p-6 rounded-2xl border border-gray-100 bg-white shadow-sm transition-all duration-500 hover:shadow-[0_15px_35px_-5px_rgba(211,60,13,0.4)] hover:border-[#D33C0D] group/elig">
            <h3 class="font-bold text-[18px] mb-4 text-gray-800 flex items-center gap-2">
               <div class="w-1.5 h-6 bg-[#D33C0D] rounded-full"></div>
               Eligibility
            </h3>
            <ul class="space-y-3 text-[15px] text-[#555]">
              <li class="flex items-start gap-2">
                <span class="text-[#D33C0D] font-bold">✓</span> Class 8 passed or 14+ years of age.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#D33C0D] font-bold">✓</span> Family income less than ₹20,000/month
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#D33C0D] font-bold">✓</span> No other Government scholarships
              </li>
            </ul>
          </div>

          <div class="p-6 rounded-2xl border border-gray-100 bg-white shadow-sm transition-all duration-500 hover:shadow-[0_15px_35px_-5px_rgba(211,60,13,0.4)] hover:border-[#D33C0D] group/dates">
            <h3 class="font-bold text-[18px] mb-4 text-gray-800 flex items-center gap-2">
              <div class="w-1.5 h-6 bg-[#D33C0D] rounded-full"></div>
              Key Timelines
            </h3>
            <div class="space-y-4 font-mono text-[13px]">
              <div class="flex justify-between border-b border-gray-100 pb-1">
                <span class="text-gray-500 uppercase tracking-wider">Deadline</span>
                <span class="text-[#D33C0D] font-bold">30 APR 2026</span>
              </div>
              <div class="flex justify-between border-b border-gray-100 pb-1">
                <span class="text-gray-500 uppercase tracking-wider">Shortlist</span>
                <span class="text-gray-800 font-bold">15 MAY 2026</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500 uppercase tracking-wider">Final Selection</span>
                <span class="text-gray-800 font-bold">02 JUN 2026</span>
              </div>
            </div>
          </div>
        </div>

        <div class="flex justify-center pt-2">
          <a
            href="https://docs.google.com/forms/d/e/1FAIpQLSf0QVTPz-FGFflZPywUXC__jOjQyfRWtzpPrJIXxiym4_aLDg/viewform"
            target="_blank"
            class="relative inline-flex items-center justify-center px-16 py-4 rounded-xl 
                   bg-[#D33C0D] text-white font-bold text-[17px] 
                   shadow-[0_10px_25px_-5px_rgba(211,60,13,0.5)]
                   hover:shadow-[0_15px_35px_-5px_rgba(211,60,13,0.7)]
                   hover:brightness-110 hover:-translate-y-1 active:scale-95
                   transition-all duration-300 group overflow-hidden"
          >
            <span class="absolute top-0 -left-full w-full h-full bg-gradient-to-r from-transparent via-white/30 to-transparent skew-x-[-30deg] group-hover:left-[120%] transition-all duration-700 ease-in-out"></span>
            <span class="relative z-10 flex items-center gap-2">
              Apply for Scholarship
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>